#!/usr/bin/make -f

export DH_VERBOSE = 1
export CGO_ENABLED = 0

RELEASE_GOFLAGS := $(if $(DNS_UPDATE_RELEASE_GOFLAGS),$(DNS_UPDATE_RELEASE_GOFLAGS),-mod=readonly -trimpath -buildvcs=false)
PACKAGE_VERSION := $(shell dpkg-parsechangelog -SVersion | sed 's/-[^-]*$$//')
RELEASE_LDFLAGS := $(if $(DNS_UPDATE_RELEASE_LDFLAGS),$(DNS_UPDATE_RELEASE_LDFLAGS),-s -w -buildid= -X dns-update/internal/buildinfo.Version=$(PACKAGE_VERSION))

# Release package builds bias for smaller binaries while keeping the normal Go
# optimizer defaults intact. Dev and test builds do not use these flags.
export GOFLAGS = $(RELEASE_GOFLAGS)

PACKAGE := dns-update
BUILD_DIR := $(CURDIR)/debian/.build
BINARY := $(BUILD_DIR)/dns-update

%:
	dh $@

override_dh_auto_build:
	set -eu; \
	host_arch="$${DEB_HOST_ARCH:-$$(dpkg-architecture -qDEB_HOST_ARCH)}"; \
	case "$$host_arch" in \
	  amd64) export GOOS=linux GOARCH=amd64 ;; \
	  arm64) export GOOS=linux GOARCH=arm64 ;; \
	  armhf) export GOOS=linux GOARCH=arm GOARM=7 ;; \
	  *) echo "unsupported Debian host architecture: $$host_arch" >&2; exit 1 ;; \
	esac; \
	mkdir -p $(BUILD_DIR); \
	go build -ldflags "$(RELEASE_LDFLAGS)" -o $(BINARY) ./cmd/dns-update

override_dh_auto_test:
	host_arch="$${DEB_HOST_ARCH:-$$(dpkg-architecture -qDEB_HOST_ARCH)}"; \
	build_arch="$${DEB_BUILD_ARCH:-$$(dpkg-architecture -qDEB_BUILD_ARCH)}"; \
	if [ "$$host_arch" != "$$build_arch" ]; then \
	  echo "Skipping tests for cross-build $$build_arch -> $$host_arch"; \
	elif ! echo "$(DEB_BUILD_OPTIONS)" | grep -Eq '(^| )nocheck( |$$)'; then \
	  DNS_UPDATE_SKIP_COVERAGE_TEST=1 DNS_UPDATE_SKIP_MUTATION_TEST=1 go test ./...; \
	fi

override_dh_auto_install:
	install -D -m 0755 $(BINARY) $(CURDIR)/debian/$(PACKAGE)/usr/bin/dns-update
	dh_install

override_dh_fixperms:
	dh_fixperms
	chmod 0644 $(CURDIR)/debian/$(PACKAGE)/etc/dns-update/dns-update.env
	chmod 0644 $(CURDIR)/debian/$(PACKAGE)/etc/dns-update/config.example.json
	chmod 0600 $(CURDIR)/debian/$(PACKAGE)/etc/dns-update/cloudflare.token.example

override_dh_auto_clean:
	rm -rf $(BUILD_DIR)
	dh_auto_clean

override_dh_installsystemd:
	dh_installsystemd --no-enable --no-start

override_dh_dwz:

override_dh_strip:

override_dh_makeshlibs:

override_dh_shlibdeps:
